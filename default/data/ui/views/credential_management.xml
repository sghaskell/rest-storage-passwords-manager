<!--
  credential_management.xml  –  Modernized for Splunk 9.2+ / Cloud

  CHANGES vs. original:
  ─────────────────────────────────────────────────────────────────────────────
  1. REMOVED  script= attribute entries for bootstrap-dropdown.js,
     bootstrap-table.js, bootstrap-table-contextmenu.js.
     These third-party bundles are no longer needed since password-crud.js
     now builds the table with native DOM methods and Splunk CSS classes.

  2. REMOVED  stylesheet= attribute entries for bootstrap-table.css,
     bootstrap-dropdown.css, bootstrap-btn-danger.css.
     Same reason as above.  Splunk's built-in stylesheets provide all
     necessary table and button styles.

  3. KEPT     script="password-crud.js"  –  the single modernized JS file
     still uses the appserver/static delivery path, so it still needs to
     be declared here.

  4. KEPT     refresh="300"  –  the table auto-refresh.  password-crud.js
     now calls refreshTable() instead of location.reload() so this is
     purely additive (the browser won't do a full page reload).

  NOTE: If you migrate to the React scaffold (CredentialManager.jsx) and
  deliver it as a custom page, this XML file is replaced entirely by the
  page entry in default/data/ui/pages/.  In that case delete this file
  and the appserver/static/password-crud.js as well.
  ─────────────────────────────────────────────────────────────────────────────
-->
<dashboard version="1.1" script="password-crud.js" refresh="300">
  <label>Credential Management</label>
  <row>
    <panel>
      <html>
        <!--
          These four div IDs are the mount points password-crud.js looks for.
          Their purpose is unchanged; the content is now rendered by vanilla
          DOM methods rather than jQuery string injection.
        -->
        <div id="create-user"></div>
        <div id="update-user"></div>
        <div id="context-menu"></div>
        <div id="password-table"></div>
      </html>
    </panel>
  </row>
</dashboard>
