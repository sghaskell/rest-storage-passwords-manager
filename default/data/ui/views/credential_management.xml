<!--
  credential_management.xml  –  React-based Splunk Dashboard (v3.0.0)

  This XML file loads the React application for credential management.
  The React app is bundled and loaded via RequireJS.
  
  DEPRECATION NOTE:
  This view replaces password-crud.js (v2.x). The old file is kept for
  backward compatibility but should be removed once React version is verified.
-->
<dashboard version="1.1" script="react/bundle.js">
  <label>Credential Management</label>
  
  <row>
    <panel>
      <html>
        <div id="credential-manager-app" class="credential-manager-container">
          <!-- React app will be mounted here -->
        </div>
        
        <style>
          /* Splunk table styles */
          .splunk-table {
            width: 100%;
            border-collapse: collapse;
          }
          
          .splunk-table th,
          .splunk-table td {
            padding: 8px 12px;
            border-bottom: 1px solid #e0e0e0;
            text-align: left;
          }
          
          .splunk-table th {
            background-color: #f5f5f5;
            font-weight: 600;
          }
          
          /* Modal styles */
          .modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
          }
          
          .modal-content {
            background-color: white;
            border-radius: 8px;
            padding: 20px;
            min-width: 300px;
            max-width: 600px;
            max-height: 80vh;
            overflow: auto;
          }
          
          .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
          }
          
          .modal-header h3 {
            margin: 0;
            font-size: 18px;
          }
          
          .modal-close {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: #666;
          }
          
          .modal-body {
            margin-bottom: 16px;
          }
          
          .modal-body-content {
            background-color: #f5f5f5;
            padding: 12px;
            border-radius: 4px;
            font-family: monospace;
            white-space: pre-wrap;
            word-break: break-all;
          }
          
          .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
          }
          
          /* Form styles */
          .credential-form {
            margin-bottom: 20px;
            padding: 20px;
            background-color: #f9f9f9;
            border-radius: 8px;
          }
          
          .form-row {
            margin-bottom: 16px;
          }
          
          .form-row label {
            display: block;
            margin-bottom: 4px;
            font-weight: 500;
          }
          
          .form-row input,
          .form-row select {
            width: 100%;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 4px;
            box-sizing: border-box;
          }
          
          .form-row input.error,
          .form-row select.error {
            border-color: #ff4444;
          }
          
          .error-message {
            color: #ff4444;
            font-size: 12px;
            margin-top: 4px;
          }
          
          .form-actions {
            display: flex;
            gap: 8px;
            margin-top: 20px;
          }
          
          /* Button styles */
          .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
          }
          
          .btn-primary {
            background-color: #0070d2;
            color: white;
          }
          
          .btn-primary:hover {
            background-color: #005bb5;
          }
          
          .btn-secondary {
            background-color: #666;
            color: white;
          }
          
          .btn-secondary:hover {
            background-color: #555;
          }
          
          .btn-icon {
            background: none;
            border: none;
            font-size: 16px;
            cursor: pointer;
            padding: 4px 8px;
          }
          
          /* Table controls */
          .table-header {
            margin-bottom: 16px;
          }
          
          .credential-filter {
            width: 100%;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 4px;
            box-sizing: border-box;
          }
          
          .table-pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 16px;
          }
          
          .table-pagination button {
            padding: 6px 12px;
            background-color: #0070d2;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
          }
          
          .table-empty,
          .table-loading {
            text-align: center;
            padding: 40px;
            color: #666;
          }
          
          .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #0070d2;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
          }
          
          @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
          }
          
          /* Checkbox header */
          .checkbox-header {
            width: 40px;
            text-align: center;
          }
          
          /* Loading overlay */
          .table-loading {
            text-align: center;
            padding: 40px;
            color: #666;
          }
        </style>
        
      </html>
    </panel>
  </row>
</dashboard>
