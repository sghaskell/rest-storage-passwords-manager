<!--
  credential_management.xml  –  React-based Splunk Dashboard (v3.0.0)
-->
<dashboard version="1.1" script="react/bundle.js">
  <label>Credential Management</label>
  
  <row>
    <panel>
      <html >
        <div id="credential-manager-app" class="credential-manager-container">
          <!-- React app will be mounted here -->
        </div>
        
        <style>
           .splunk-table { width: 100%; border-collapse: collapse; }
           .splunk-table th, .splunk-table td { padding: 8px 12px; border-bottom: 1px solid #e0e0e0; text-align: left; }
           .splunk-table th { background-color: #f5f5f5; font-weight: 600; }
        </style>
      </html >
    </panel>
  </row>
</dashboard>
